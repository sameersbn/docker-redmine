#!/bin/bash
# Script to set the Redmine admin password.
# Usage: redmine-admin-password <new-password> [login]

set -e
source ${REDMINE_RUNTIME_ASSETS_DIR}/functions

if [[ -z ${1} ]]; then
  echo "Usage: $(basename "${0}") <new-password> [login]"
  exit 1
fi

# Password and login are passed as rails runner ARGV (not interpolated into the
# ruby string) to avoid quoting/injection issues with special characters.
execute_runner '
  login = ARGV[1].to_s.empty? ? "admin" : ARGV[1]
  user = User.find_by_login(login)
  abort("User #{login.inspect} not found") if user.nil?
  user.password = user.password_confirmation = ARGV[0]
  user.must_change_passwd = false
  user.save!
  puts "Updated password for #{login.inspect}"
' "${1}" "${2}"
